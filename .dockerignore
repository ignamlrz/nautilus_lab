# Keep the build context small — only what the Dockerfile actually needs.

# Git
.git
.gitignore

# Python bytecode and caches
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd

# uv / venv
.venv
venv
**/.venv

# IDE
.vscode
.idea

# Logs and local artifacts
logs
artifacts

# Docker self-reference
Dockerfile
docker-compose.yml
.dockerignore

# Local secrets / config (passed via env_file at runtime, not baked in)
.env
.env.local

# OS junk
.DS_Store
Thumbs.db
