    "version": "0.2.0",
    "configurations": [

        {
            "name": "Backtest",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": ["-c", "${workspaceFolder}/config/system/backtest.yaml", "-s", "${workspaceFolder}/config/strategies/choch-detector.yaml"],
            "justMyCode": false
        },
        {
            "name": "Live PaperTrading",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": ["-c", "${workspaceFolder}/config/system/binance-paper-trading-local.yaml", "-s", "${workspaceFolder}/config/strategies/choch-detector.yaml"],
            "justMyCode": false
        }
    ]
}
